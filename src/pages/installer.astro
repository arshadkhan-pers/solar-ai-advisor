---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout pageKey="installer.html" headerVariant="none" bodyClass="text-slate-900 font-sans relative min-h-screen overflow-x-hidden bg-slate-50" includeConsoleShield={true}>

<!-- ANIMATED BACKGROUND -->
<div class="fixed inset-0 z-[-1] pointer-events-none overflow-hidden">
  <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] rounded-full bg-indigo-300/20 filter blur-[120px] animate-blob"></div>
  <div class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] rounded-full bg-emerald-200/20 filter blur-[120px] animate-blob" style="animation-delay: 4s"></div>
</div>

<div class="max-w-xl mx-auto space-y-8 px-4 py-12 relative z-10">

<!-- TOP ACTIONS -->

<div class="flex justify-between items-center mb-8">

  <button
    onclick="history.back()"
    class="bg-white border border-slate-200 px-4 py-2 rounded-full text-sm font-semibold hover:bg-slate-50 transition shadow-sm">

    ← Back

  </button>

  <a
    href="index.html"
    class="bg-white border border-slate-200 px-4 py-2 rounded-full text-sm font-semibold hover:bg-slate-50 transition shadow-sm">

    🏠 Home

  </a>

</div>

  <!-- HEADER -->
  <div class="text-center space-y-3">
    <p class="text-indigo-600 font-bold text-xs uppercase tracking-widest">Partner Program</p>
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Get Solar Leads in Your City</h1>
    <p class="text-slate-500">Verified homeowners. High-intent customers.</p>
  </div>

  <!-- MAIN CONTAINER -->
  <div class="bg-white/90 backdrop-blur-sm rounded-3xl shadow-premium border border-slate-200/75 overflow-hidden">
    
    <!-- FORM SECTION -->
    <div id="formSection" class="p-6 md:p-8 space-y-6">
      <h3 class="font-bold text-xl text-center text-slate-900">Installer Signup</h3>
      
      <form id="installerForm" class="space-y-4">
        <div>
          <input type="text" id="business" placeholder="Business Name" required class="w-full p-3.5 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500">
          <p id="businessError" class="text-red-500 text-xs mt-1 ml-1"></p>
        </div>

        <div>
          <input type="text" id="name" placeholder="Contact Person" required class="w-full p-3.5 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500">
          <p id="nameError" class="text-red-500 text-xs mt-1 ml-1"></p>
        </div>

        <div>
          <input type="tel" id="phone" placeholder="Phone Number (10 digits)" required class="w-full p-3.5 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500">
          <p id="phoneError" class="text-red-500 text-xs mt-1 ml-1"></p>
        </div>

        <div>
          <select id="state" required class="w-full p-3.5 border border-slate-200 rounded-xl bg-white text-slate-700 outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">Select State</option>
            <option value="AP">Andhra Pradesh</option>
            <option value="AS">Assam</option>
            <option value="BR">Bihar</option>
            <option value="DL">Delhi</option>
            <option value="GA">Goa</option>
            <option value="GJ">Gujarat</option>
            <option value="HR">Haryana</option>
            <option value="HP">Himachal Pradesh</option>
            <option value="JH">Jharkhand</option>
            <option value="KA">Karnataka</option>
            <option value="KL">Kerala</option>
            <option value="MP">Madhya Pradesh</option>
            <option value="MH">Maharashtra</option>
            <option value="OR">Odisha</option>
            <option value="PB">Punjab</option>
            <option value="RJ">Rajasthan</option>
            <option value="TN">Tamil Nadu</option>
            <option value="TS">Telangana</option>
            <option value="UP">Uttar Pradesh</option>
            <option value="UK">Uttarakhand</option>
            <option value="WB">West Bengal</option>
          </select>
          <p id="stateError" class="text-red-500 text-xs mt-1 ml-1"></p>
        </div>

        <!-- Replace the City & Areas grid with this -->
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
  <div>
    <select id="city" required class="w-full p-3.5 border border-slate-200 rounded-xl bg-white text-slate-700 outline-none focus:ring-2 focus:ring-indigo-500">
      <option value="">Select City</option>
    </select>
    <p id="cityError" class="text-red-500 text-xs mt-1 ml-1"></p>
  </div>
  <div>
    <select id="experience" required class="w-full p-3.5 border border-slate-200 rounded-xl bg-white text-slate-700 outline-none focus:ring-2 focus:ring-indigo-500">
      <option value="">Experience (Years)</option>
      <option value="1-2">1-2 Years</option>
      <option value="3-5">3-5 Years</option>
      <option value="6+">6+ Years</option>
    </select>
  </div>
</div>

        <div>
          <input type="text" id="areas" placeholder="Service Areas (comma separated)" required class="w-full p-3.5 border border-slate-200 rounded-xl outline-none focus:ring-2 focus:ring-indigo-500">
        </div>

        <button
  type="submit"
  id="submitBtn"
  class="w-full bg-green-700 hover:bg-green-800 text-white py-4 rounded-xl font-semibold shadow-premium transition-all transform hover:-translate-y-0.5">
  Register as Installer
</button>

      </form>
      <p class="text-[10px] text-slate-400 text-center uppercase tracking-wider">Manual Review Required for Activation</p>
    </div>

    <!-- SUCCESS MESSAGE -->
    <div id="successMsg" class="hidden p-8 text-center space-y-4">
      <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto">
  <span class="text-[#22c55e] text-2xl">✓</span>
</div>
      <h3 class="font-bold text-2xl text-slate-900">Registration Received!</h3>
      <p class="text-slate-600">Your details have been captured successfully. Our team will review your profile and contact you shortly.</p>
    </div>
  </div>

  <!-- TRUST BAR -->
  <div class="flex flex-col sm:flex-row items-center justify-center gap-6 text-sm font-medium text-slate-500">
    <div class="flex items-center gap-2"><span>✔</span> Local City Matching</div>
    <div class="flex items-center gap-2"><span>✔</span> Verified Intent</div>
    <div class="flex items-center gap-2"><span>✔</span> Free First Leads</div>
  </div>
</div>
<!-- FOOTER -->

<!-- SCRIPTS -->
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js" is:inline></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-firestore.js" is:inline></script>
<script src="js/locationUtils.js" is:inline></script>
<script src="js/installer.js" is:inline></script>

</BaseLayout>

    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <div class="p-10 rounded-[2.5rem] bg-white shadow-sm border border-slate-100">
        <div class="w-12 h-12 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center font-bold mb-6 mx-auto">
          01

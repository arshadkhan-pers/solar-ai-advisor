---
// Visible counterpart to the BreadcrumbList JSON-LD already emitted by SEOHead.astro
// for the same pages — same data source, same Home -> current-page shape.
import seoData from "../../data/seo-metadata.json";

interface Props {
  pageKey: string;
}

const { pageKey } = Astro.props;
const page = seoData.pages[pageKey];
const breadcrumbLabel = page?.breadcrumbLabel;
---
{
  breadcrumbLabel && (
    <nav aria-label="Breadcrumb" class="bg-slate-50 border-b border-slate-100 px-4 md:px-8 py-3">
      <ol class="max-w-7xl mx-auto flex items-center gap-2 text-sm text-slate-500">
        <li>
          <a href="index.html" class="hover:text-slate-900 transition-colors">Home</a>
        </li>
        <li aria-hidden="true">/</li>
        <li class="text-slate-900 font-medium" aria-current="page">
          {breadcrumbLabel}
        </li>
      </ol>
    </nav>
  )
}

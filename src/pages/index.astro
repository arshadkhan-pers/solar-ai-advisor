<!-- END MENU DRAWER -->

<section class="relative min-h-[95vh] flex items-center justify-center text-center text-white overflow-hidden pt-24">

  <video autoplay muted loop playsinline fetchpriority="high" class="absolute w-full h-full object-cover">
    <source src="images/hero.mp4" type="video/mp4">
  </video>

  <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/40 to-black/80"></div>

  <div class="relative z-10 max-w-4xl px-6 py-10">

      <h1 class="text-4xl md:text-6xl font-bold mb-4 leading-tight tracking-tight">
        Know Your Solar Potential
        <br>
        In 60 Seconds
    </h1>

    <p class="text-gray-200 text-lg md:text-xl mb-10 max-w-2xl mx-auto">
      Free AI-powered solar assessment,
      subsidy intelligence,
      and verified installer matching.
      No obligation. No hidden fees.
   </p>

<!-- Calculation Mode Toggle -->

<div class="flex justify-center mb-5">
  <div class="bg-white/10 backdrop-blur-sm rounded-full p-1 border border-white/20 flex">

    <button
      id="billModeBtn"
      onclick="switchCalculationMode('bill')"
      class="px-5 py-2 rounded-full bg-white text-slate-900 text-sm font-semibold">
      Monthly Bill
    </button>

    <button
      id="kwModeBtn"
      onclick="switchCalculationMode('kw')"
      class="px-5 py-2 rounded-full text-white text-sm font-semibold">
      System Size (kW)
    </button>

  </div>
</div>

    <div class="flex flex-col md:flex-row gap-4 justify-center items-start bg-white/10 backdrop-blur-md p-6 rounded-[2rem] border border-white/20 shadow-2xl">

     <!-- BILL MODE -->

<div
  id="billInputContainer"
  class="w-full md:w-64 text-left">

  <input
    id="billInput"
    type="number"
    inputmode="numeric"
    placeholder="Monthly bill (₹)"
    class="w-full px-5 py-4 rounded-2xl text-black shadow-inner outline-none focus:ring-2 focus:ring-green-400 transition-all bg-white"
  />

  <p id="billError"
     class="text-red-400 text-[11px] mt-1.5 ml-1 font-medium min-h-[1rem]">
  </p>

</div>

<!-- KW MODE -->

<div
  id="kwInputContainer"
  class="hidden w-full md:w-64 text-left">

  <select
    id="systemSizeInput"
    class="w-full px-5 py-4 rounded-2xl text-black shadow-inner outline-none focus:ring-2 focus:ring-green-400 transition-all bg-white">

    <option value="1">1 kW</option>
    <option value="2">2 kW</option>
    <option value="3" selected>3 kW</option>
    <option value="4">4 kW</option>
    <option value="5">5 kW</option>
    <option value="6">6 kW</option>
    <option value="8">8 kW</option>
    <option value="10">10 kW</option>
  </select>

</div>

      <div class="w-full md:w-64 text-left">
  <input
    id="pincodeInput"
    type="text"
    pattern="[0-9]*"
    inputmode="numeric"
    maxlength="6"
    placeholder="6-Digit PIN Code"
    class="w-full px-5 py-4 rounded-2xl text-black shadow-inner outline-none focus:ring-2 focus:ring-green-400 transition-all bg-white"
    oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0, 6);"
  />
  <p id="pincodeError" class="text-red-400 text-[11px] mt-1.5 ml-1 font-medium min-h-[1rem]"></p>
  
  <p id="locationFeedbackMsg" class="min-h-[1rem] text-xs font-medium text-left ml-1"></p>
</div>

      <button
        onclick="handleHeroCalculate()"
        class="w-full md:w-auto bg-green-700 hover:bg-green-800 px-8 py-4 rounded-2xl font-bold shadow-lg transition-all hover:-translate-y-0.5 active:scale-95 text-white whitespace-nowrap">
        ⚡ See My Savings
      </button>
    </div>

    <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-3 max-w-4xl mx-auto">

  <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-3 border border-white/10">
    <div class="text-xs text-white/60">Role</div>
    <div class="text-white font-semibold">
      Free Independent Advisor
    </div>
  </div>

  <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-3 border border-white/10">
    <div class="text-xs text-white/60">Installers</div>
    <div class="text-white font-semibold">
      Verified Only
    </div>
  </div>

  <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-3 border border-white/10">
    <div class="text-xs text-white/60">Costs</div>
    <div class="text-white font-semibold">
      Fully Transparent
    </div>
  </div>

  <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-3 border border-white/10">
    <div class="text-xs text-white/60">Recommendations</div>
    <div class="text-white font-semibold">
      Unbiased
    </div>
  </div>
</div>

<!-- NEW: Existing User Sign-In Link -->
<div class="mt-2 text-center text-sm text-gray-200">
  Existing user? <a href="#" onclick="openSignInModal(event)" class="underline hover:text-white transition-colors">Sign in here</a>
</div>

    <button
      onclick="window.location.href='installer.html'"
      class="mt-10 text-white/60 hover:text-white transition-colors text-sm border-b border-white/20 pb-1">

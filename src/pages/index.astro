      </div>
      <div>
        <input id="leadPhone" type="text" inputmode="numeric" maxlength="10" placeholder="Phone Number (Mandatory)" class="w-full p-4 border border-slate-200 rounded-2xl outline-none focus:ring-2 focus:ring-green-500"/>

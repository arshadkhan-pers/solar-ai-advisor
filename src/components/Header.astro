---
// Only the "policy" variant (Pattern C nav: text logo + "Back Home") is implemented.
// "home" and "guide" variants land in a later migration phase.
interface Props {
  variant?: "policy" | "home" | "guide";
}

const { variant = "policy" } = Astro.props;
---
{
  variant === "policy" && (
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="index.html" class="font-bold text-xl text-slate-900">
          Solar AI Advisor
        </a>
        <a
          href="index.html"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >
          ← Back Home
        </a>
      </div>
    </nav>
  )
}

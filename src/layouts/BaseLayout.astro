---
import SEOHead from "../components/SEOHead.astro";
import Header from "../components/Header.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  pageKey: string;
  headerVariant?: "policy" | "home" | "guide" | "none";
  includeFooter?: boolean;
  bodyClass?: string;
  includeConsoleShield?: boolean;
}

const {
  pageKey,
  headerVariant = "policy",
  includeFooter = true,
  bodyClass = "bg-slate-50 text-slate-900",
  includeConsoleShield = false,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<SEOHead pageKey={pageKey} />

{includeConsoleShield && <script src="js/console-shield.js" is:inline></script>}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
body{
font-family:'Inter',sans-serif;
}
</style>

</head>

<body class={bodyClass}>

<Header variant={headerVariant} />

<Breadcrumb pageKey={pageKey} />

<slot />

{includeFooter && <Footer />}

</body>
</html>

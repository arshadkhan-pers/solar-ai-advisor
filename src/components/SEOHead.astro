---
// Single source of truth for per-page SEO tags, driven by data/seo-metadata.json.
import seoData from "../../data/seo-metadata.json";

interface Props {
  pageKey: string;
}

const { pageKey } = Astro.props;
const page = seoData.pages[pageKey];
if (!page) {
  throw new Error(`No SEO metadata found for pageKey "${pageKey}" in data/seo-metadata.json`);
}

const site = seoData.site;

function absoluteUrl(path) {
  return path ? `${site.baseUrl}/${path}` : `${site.baseUrl}/`;
}

const url = page.skipFullSeo ? null : absoluteUrl(page.path);
const ogImage = page.skipFullSeo ? null : absoluteUrl(page.ogImage || site.defaultOgImage);

const jsonLdBlocks = [];
if (!page.skipFullSeo) {
  if (page.isHome) {
    // --- LocalBusiness (Organisation node) ---
    const orgNode: Record<string, unknown> = {
      "@type": "LocalBusiness",
      "@id": `${site.baseUrl}/#organization`,
      name: site.organization.name,
      url: site.organization.url,
      logo: site.organization.logo,
      email: site.organization.email,
      description: site.organization.description,
      address: {
        "@type": "PostalAddress",
        ...site.organization.address,
      },
    };
    if (site.organization.areaServed) orgNode.areaServed = site.organization.areaServed;
    if (site.organization.geo) {
      orgNode.geo = {
        "@type": "GeoCoordinates",
        latitude: site.organization.geo.latitude,
        longitude: site.organization.geo.longitude,
      };
    }
    if (site.organization.sameAs) orgNode.sameAs = site.organization.sameAs;

    // --- WebSite with potentialAction (calculator as primary action) ---
    const websiteNode: Record<string, unknown> = {
      "@type": "WebSite",
      "@id": `${site.baseUrl}/#website`,
      name: site.name,
      url: site.baseUrl,
      publisher: { "@id": `${site.baseUrl}/#organization` },
      potentialAction: {
        "@type": "SearchAction",
        target: {
          "@type": "EntryPoint",
          urlTemplate: `${site.baseUrl}/?bill={search_term}`,
        },
        "query-input": "required name=search_term",
      },
    };

    // --- SoftwareApplication (AI calculator declaration) ---
    const softwareNode: Record<string, unknown> = {
      "@type": "SoftwareApplication",
      name: "Solar Savings Calculator",
      applicationCategory: "UtilityApplication",
      operatingSystem: "Web",
      description: "Free AI-powered rooftop solar savings calculator for Indian homeowners. Estimate bill savings, system size, and payback period in under 60 seconds.",
      url: site.baseUrl,
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "INR",
      },
    };

    jsonLdBlocks.push({
      "@context": "https://schema.org",
      "@graph": [orgNode, websiteNode, softwareNode],
    });
  } else if (page.breadcrumbLabel) {
    jsonLdBlocks.push({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${site.baseUrl}/` },
        { "@type": "ListItem", position: 2, name: page.breadcrumbLabel, item: url },
      ],
    });
  }

  // --- Article schema for kW system pages and city guide pages ---
  if (!page.isHome && page.ogType === "article") {
    jsonLdBlocks.push({
      "@context": "https://schema.org",
      "@type": "Article",
      headline: page.title,
      description: page.description,
      mainEntityOfPage: url,
      datePublished: page.publishedDate || "2026-01-01",
      author: { "@id": `${site.baseUrl}/#organization` },
      publisher: { "@id": `${site.baseUrl}/#organization` },
    });
  }

  // --- Service schema for city pages ---
  if (page.serviceArea) {
    jsonLdBlocks.push({
      "@context": "https://schema.org",
      "@type": "Service",
      name: "Rooftop Solar Advisory",
      provider: { "@id": `${site.baseUrl}/#organization` },
      areaServed: { "@type": "City", name: page.serviceArea },
      description: page.description,
    });
  }

  // --- FAQPage ---
  if (page.faq && page.faq.length) {
    jsonLdBlocks.push({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: page.faq.map((qa) => ({
        "@type": "Question",
        name: qa.question,
        acceptedAnswer: { "@type": "Answer", text: qa.answer },
      })),
    });
  }
}
---
<title>{page.title}</title>
<meta name="robots" content={page.robots} />
{!page.skipFullSeo && (
  <>
    <meta name="description" content={page.description} />
    <link rel="canonical" href={url} />
    <meta property="og:type" content={page.ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={page.title} />
    <meta name="twitter:description" content={page.description} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </>
)}

</section>

<section id="how-it-works" class="py-24 bg-slate-50 text-center scroll-mt-20">

  <div class="max-w-5xl mx-auto px-6">

    <h2 class="text-3xl md:text-5xl font-bold text-[#171a20] mb-4">
        Go Solar With Confidence

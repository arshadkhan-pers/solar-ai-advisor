---
// "policy" (Pattern C: text logo + "Back Home"), "guide" (Pattern B: text logo +
// "Calculate Savings" CTA), and "home" (Pattern A: image logo + nav links) are
// implemented. The mobile drawer itself is page-specific body content on
// index.html, not part of this component.
interface Props {
  variant?: "policy" | "home" | "guide";
}

const { variant = "policy" } = Astro.props;
---
{
  variant === "policy" && (
    <header class="sticky top-0 z-50 bg-white border-b border-slate-200">
      {/* Top bar */}
      <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
        <a href="index.html" class="font-bold text-lg text-slate-900">
          Solar AI Advisor
        </a>
        <a
          href="index.html"
          class="text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors"
        >
          ← Home
        </a>
      </div>
      {/* Knowledge nav strip — scrollable on mobile, inline on desktop */}
      <div class="border-t border-slate-100 bg-slate-50 overflow-x-auto scrollbar-none">
        <nav class="flex gap-1 px-4 py-2 min-w-max md:min-w-0 md:max-w-7xl md:mx-auto">
          <a href="learn.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap">
            Knowledge Center
          </a>
          <a href="faq.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap">
            Solar FAQ
          </a>
          <a href="solar-glossary.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap">
            Glossary
          </a>
          <a href="cities.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap">
            Solar by City
          </a>
          <span class="text-slate-200 px-1 hidden md:inline">|</span>
          <a href="1kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            1kW
          </a>
          <a href="2kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            2kW
          </a>
          <a href="3kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            3kW
          </a>
          <a href="5kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            5kW
          </a>
          <a href="10kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            10kW
          </a>
        </nav>
      </div>
    </header>
  )
}
{
  variant === "guide" && (
    <header class="bg-white border-b border-slate-200 sticky top-0 z-50">
      {/* Top bar */}
      <div class="max-w-6xl mx-auto px-4 py-3 flex justify-between items-center">
        <a href="index.html" class="font-bold text-lg text-slate-900">
          Solar AI Advisor
        </a>
        <a
          href="index.html"
          class="bg-emerald-600 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-emerald-700 transition"
        >
          Calculate Savings
        </a>
      </div>
      {/* Knowledge nav strip */}
      <div class="border-t border-slate-100 bg-slate-50 overflow-x-auto scrollbar-none">
        <nav class="flex gap-1 px-4 py-2 min-w-max md:min-w-0 md:max-w-6xl md:mx-auto">
          <a href="learn.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap">
            Knowledge Center
          </a>
          <a href="faq.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap">
            Solar FAQ
          </a>
          <a href="solar-glossary.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap">
            Glossary
          </a>
          <a href="cities.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap">
            Solar by City
          </a>
          <span class="text-slate-200 px-1 hidden md:inline">|</span>
          <a href="1kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            1kW
          </a>
          <a href="2kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            2kW
          </a>
          <a href="3kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            3kW
          </a>
          <a href="5kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            5kW
          </a>
          <a href="10kw-solar-system.html"
             class="px-3 py-1.5 rounded-full text-xs font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition-colors whitespace-nowrap hidden md:inline-block">
            10kW
          </a>
        </nav>
      </div>
    </header>
  )
}
{
  variant === "home" && (
    <nav class="fixed top-0 left-0 w-full z-[110] bg-white border-b border-slate-100 px-4 md:px-8 py-3">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="index.html" class="flex items-center">
          <img
            src="images/logo.webp"
            alt="Solar AI Advisor"
            width="1536"
            height="1024"
            decoding="async"
            class="h-16 md:h-20 w-auto"
          />
        </a>

        <div class="flex items-center gap-4">
          <a
            href="#how-it-works"
            class="hidden md:block text-slate-600 hover:text-slate-900 text-sm font-medium transition-colors"
          >
            How it Works
          </a>

          <button
            onclick="openConsultation()"
            class="hidden md:block bg-[#171a20] text-white px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-[#393c41] transition-all shadow-md"
          >
            Free Consultation
          </button>

          <button
            onclick="openMenu()"
            class="bg-white border border-slate-200 px-4 py-2 rounded-full text-sm font-semibold hover:bg-slate-50 transition"
          >
            ☰ Explore
          </button>
        </div>
      </div>
    </nav>
  )
}

---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout pageKey="about.html" headerVariant="policy">

<!-- HERO -->

<section class="py-24 bg-gradient-to-br from-slate-900 to-slate-800 text-white">

<div class="max-w-4xl mx-auto px-6 text-center">

<div class="uppercase tracking-widest text-sm text-indigo-300 mb-4">
OUR MISSION
</div>

<h1 class="text-5xl font-bold mb-6">
India's Independent Solar Advisor
</h1>

<p class="text-xl text-slate-300 max-w-3xl mx-auto">
Helping homeowners make smarter solar decisions through
AI-powered analysis, transparent pricing intelligence,
and installer-neutral recommendations.
</p>

</div>
</section>

<!-- STORY -->

<section class="py-20">

<div class="max-w-5xl mx-auto px-6">

<h2 class="text-4xl font-bold mb-8">
Why We Built Solar AI Advisor
</h2>

<div class="space-y-6 text-lg text-slate-600 leading-relaxed">

<p>
Buying rooftop solar should be simple.
Unfortunately, many homeowners receive conflicting quotes,
confusing subsidy information, and aggressive sales pitches.
</p>

<p>
Solar AI Advisor was created to bring transparency to the solar buying process.
Our platform helps homeowners understand:
</p>

<ul class="list-disc pl-6 space-y-3">

<li>Recommended solar system size</li>

<li>Estimated installation cost</li>

<li>Government subsidy eligibility</li>

<li>Expected savings and payback</li>

<li>Installer readiness and buyer protection guidance</li>

</ul>

<p>
Our goal is simple:
help Indian homeowners go solar with confidence.
</p>

</div>

</div>
</section>

<!-- VALUES -->

<section class="py-20 bg-white">

<div class="max-w-6xl mx-auto px-6">

<h2 class="text-4xl font-bold text-center mb-14">
Our Principles
</h2>

<div class="grid md:grid-cols-3 gap-8">

<div class="bg-slate-50 p-8 rounded-3xl">
<div class="text-4xl mb-4">⚖️</div>
<h3 class="font-bold text-xl mb-3">
Installer Neutral
</h3>
<p class="text-slate-600">
We do not rank installers based on commissions.
Recommendations prioritize quality and suitability.
</p>
</div>

<div class="bg-slate-50 p-8 rounded-3xl">
<div class="text-4xl mb-4">🤖</div>
<h3 class="font-bold text-xl mb-3">
AI Powered
</h3>
<p class="text-slate-600">
Advanced algorithms analyze energy usage,
savings potential, and subsidy opportunities.
</p>
</div>

<div class="bg-slate-50 p-8 rounded-3xl">
<div class="text-4xl mb-4">🔒</div>
<h3 class="font-bold text-xl mb-3">
Privacy First
</h3>
<p class="text-slate-600">
Your information is protected and handled in accordance with Indian privacy regulations.
</p>
</div>

</div>

</div>
</section>

<!-- STATS -->

<section class="py-20">

<div class="max-w-5xl mx-auto px-6">

<div class="grid md:grid-cols-3 gap-6 text-center">

<div class="bg-white p-8 rounded-3xl shadow-sm">
<div class="text-4xl font-bold text-indigo-600">
AI
</div>
<div class="text-slate-500 mt-2">
Powered Analysis
</div>
</div>

<div class="bg-white p-8 rounded-3xl shadow-sm">
<div class="text-4xl font-bold text-emerald-600">
100%
</div>
<div class="text-slate-500 mt-2">
Independent Advice
</div>
</div>

<div class="bg-white p-8 rounded-3xl shadow-sm">
<div class="text-4xl font-bold text-amber-500">
24/7
</div>
<div class="text-slate-500 mt-2">
Digital Availability
</div>
</div>

</div>

</div>
</section>

<!-- CTA -->

<section class="py-24 bg-slate-900 text-white text-center">

<div class="max-w-3xl mx-auto px-6">

<h2 class="text-4xl font-bold mb-6">
Ready To Discover Your Solar Potential?
</h2>

<p class="text-slate-300 mb-8">
Get a personalized solar savings estimate in less than 60 seconds.
</p>

<a href="index.html"
class="inline-block bg-emerald-600 hover:bg-emerald-700 px-8 py-4 rounded-2xl font-bold">
Calculate My Savings
</a>

</div>

</section>

</BaseLayout>

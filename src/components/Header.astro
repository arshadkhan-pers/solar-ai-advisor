---
// "policy" (Pattern C: text logo + "Back Home") and "guide" (Pattern B: text logo
// + "Calculate Savings" CTA) are implemented. "home" (Pattern A: image logo + mobile
// drawer menu) lands in a later migration phase.
interface Props {
  variant?: "policy" | "home" | "guide";
}

const { variant = "policy" } = Astro.props;
---
{
  variant === "policy" && (
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="index.html" class="font-bold text-xl text-slate-900">
          Solar AI Advisor
        </a>
        <a
          href="index.html"
          class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
        >
          ← Back Home
        </a>
      </div>
    </nav>
  )
}
{
  variant === "guide" && (
    <nav class="bg-white border-b border-slate-200">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="index.html" class="font-bold text-xl">
          Solar AI Advisor
        </a>
        <a
          href="index.html"
          class="bg-emerald-600 text-white px-5 py-2 rounded-xl font-semibold hover:bg-emerald-700 transition"
        >
          Calculate Savings
        </a>
      </div>
    </nav>
  )
}

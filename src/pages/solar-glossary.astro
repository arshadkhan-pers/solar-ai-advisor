---
import BaseLayout from "../layouts/BaseLayout.astro";

const terms = [
  {
    term: "ALMM",
    definition: "Approved List of Models and Manufacturers — MNRE's registry of solar panels and inverters meeting quality standards for government-linked projects. Panels must be ALMM-listed for PM Surya Ghar subsidy eligibility."
  },
  {
    term: "Annual Maintenance Contract (AMC)",
    definition: "A service agreement with a solar installer covering periodic inspections, cleaning, and minor repairs over a defined period. AMCs typically run 1–5 years and help ensure consistent system performance."
  },
  {
    term: "Battery Storage",
    definition: "An optional component that stores surplus solar electricity for use when the sun is not shining. Common in off-grid and hybrid systems. On-grid systems in India often operate without batteries, using net metering instead."
  },
  {
    term: "Capacity Utilisation Factor (CUF)",
    definition: "The ratio of actual energy generated by a solar system to the theoretical maximum it could generate if operating at full capacity continuously. A CUF of 17–20% is typical for rooftop solar in India."
  },
  {
    term: "Channel Partner (MNRE)",
    definition: "An installer empanelled by MNRE to carry out rooftop solar installations under government schemes. Using an empanelled channel partner is mandatory to claim PM Surya Ghar subsidy."
  },
  {
    term: "DBT (Direct Benefit Transfer)",
    definition: "The mechanism by which PM Surya Ghar subsidies are disbursed directly to the homeowner's bank account after successful installation and inspection, bypassing intermediaries."
  },
  {
    term: "DISCOM",
    definition: "Distribution Company — the local electricity distribution utility that delivers power to your home. DISCOMs handle net metering applications, meter upgrades, and net metering account statements. Examples: UPPCL in Uttar Pradesh, TPDDL in Delhi."
  },
  {
    term: "Feed-in Tariff",
    definition: "A rate at which utilities pay for electricity exported from a solar system to the grid. India uses net metering rather than a fixed feed-in tariff for most residential solar; export credits offset import charges at the applicable tariff rate."
  },
  {
    term: "Grid-Tied / On-Grid System",
    definition: "A solar system connected to the utility grid. Surplus generation is exported to the grid (credited via net metering) and the grid supplies electricity when solar generation is insufficient. The most common type of residential solar in India."
  },
  {
    term: "Hybrid Solar System",
    definition: "A solar system that combines grid connection with battery storage. Allows homeowners to store surplus solar electricity and use it during power cuts, while still exporting excess to the grid."
  },
  {
    term: "Inverter",
    definition: "A device that converts DC electricity from solar panels into AC electricity usable in your home. Types include string inverters (one per array), microinverters (one per panel), and hybrid inverters (with battery compatibility). Inverter life is typically 10–15 years."
  },
  {
    term: "kWh (Kilowatt-Hour)",
    definition: "The standard unit of electricity consumption and generation. One kWh = 1 unit on your electricity bill. A 3kW solar system in India generates approximately 3,900–4,500 kWh per year."
  },
  {
    term: "kWp (Kilowatt-Peak)",
    definition: "The rated maximum power output of a solar panel or system under Standard Test Conditions (STC). A 3kWp system has panels with a combined peak output of 3,000 watts. Actual generation is lower due to real-world conditions."
  },
  {
    term: "MNRE",
    definition: "Ministry of New and Renewable Energy — India's central government ministry responsible for solar energy policy, subsidies, empanelment of installers, and the PM Surya Ghar scheme."
  },
  {
    term: "Monocrystalline Panel",
    definition: "A solar panel made from a single silicon crystal, offering higher efficiency (20–23%) and better performance in limited roof space. The dominant technology in new residential installations in India."
  },
  {
    term: "Net Metering",
    definition: "A billing arrangement where electricity exported to the grid is credited against electricity imported from the grid. Your DISCOM installs a bidirectional meter, and you pay only for net consumption. Essential for maximising rooftop solar value."
  },
  {
    term: "Off-Grid System",
    definition: "A solar system that operates independently of the utility grid. Requires battery storage for power at night or during low-generation periods. Suited for areas without reliable grid access; not eligible for PM Surya Ghar subsidy."
  },
  {
    term: "Payback Period",
    definition: "The time taken for cumulative electricity savings to equal the initial system cost (after subsidy). Typical payback for well-sized on-grid systems in India is 4–7 years; the system then continues generating for 20+ more years."
  },
  {
    term: "PERC (Passivated Emitter and Rear Cell)",
    definition: "A monocrystalline panel technology that improves efficiency by adding a passivation layer to the rear of the cell. PERC panels dominate the residential solar market and offer a good balance of efficiency and cost."
  },
  {
    term: "PM Surya Ghar Muft Bijli Yojana",
    definition: "India's flagship central government scheme for residential rooftop solar, launched in 2024. Provides central subsidies (up to ₹94,500 for systems up to 10kW) and enables 300 free units of electricity per month for eligible households."
  },
  {
    term: "Polycrystalline Panel",
    definition: "A solar panel made from multiple silicon fragments, offering slightly lower efficiency than monocrystalline at a marginally lower cost. Less common in new residential installations, as the cost gap with monocrystalline has narrowed."
  },
  {
    term: "Rooftop Solar",
    definition: "A photovoltaic (PV) system installed on the roof of a building to generate electricity from sunlight. Includes panels, inverter, mounting structure, wiring, and (optionally) batteries. The focus of Solar AI Advisor's advisory services."
  },
  {
    term: "Solar Irradiance",
    definition: "The power of sunlight reaching a surface, measured in watts per square metre (W/m²). India receives excellent solar irradiance, averaging 4–6 kWh/m²/day across most regions — among the best in the world for solar generation."
  },
  {
    term: "String Inverter",
    definition: "An inverter connected to a series (string) of solar panels. The most common inverter type for residential systems; cost-effective but sensitive to shading — if one panel underperforms, it affects the whole string."
  },
  {
    term: "TOPCon (Tunnel Oxide Passivated Contact)",
    definition: "A next-generation monocrystalline panel technology offering higher efficiency (22–24%) than standard PERC. Increasingly available in the Indian market; typically commands a small price premium over PERC."
  }
];

const letters = [...new Set(terms.map(t => t.term[0].toUpperCase()))].sort();
---
<BaseLayout pageKey="solar-glossary.html" headerVariant="policy">

<section class="bg-gradient-to-br from-slate-900 to-slate-800 text-white py-24">
<div class="max-w-4xl mx-auto px-6 text-center">
<div class="uppercase tracking-widest text-indigo-300 text-sm mb-4">REFERENCE</div>
<h1 class="text-5xl font-bold mb-6">Solar Glossary</h1>
<p class="text-xl text-slate-300 max-w-2xl mx-auto">
  Plain-language definitions for solar energy terms used in India — from ALMM to TOPCon.
</p>
</div>
</section>

<!-- ALPHA NAV -->
<nav class="bg-white border-b border-slate-100">
<div class="max-w-4xl mx-auto px-6 py-3 flex flex-wrap gap-2">
  {letters.map(letter => (
    <a href={`#letter-${letter}`} class="px-3 py-1 rounded-lg text-sm font-semibold text-slate-600 hover:bg-indigo-50 hover:text-indigo-600 transition">
      {letter}
    </a>
  ))}
</div>
</nav>

<div class="max-w-4xl mx-auto px-6 py-20">

  {letters.map(letter => {
    const group = terms.filter(t => t.term[0].toUpperCase() === letter);
    return (
      <div id={`letter-${letter}`} class="mb-12 scroll-mt-20">
        <h2 class="text-2xl font-bold text-indigo-600 mb-6 pb-2 border-b border-slate-200">{letter}</h2>
        <dl class="space-y-6">
          {group.map(({ term, definition }) => (
            <div id={term.toLowerCase().replace(/[^a-z0-9]+/g, '-')} class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 scroll-mt-24">
              <dt class="font-bold text-lg text-slate-900 mb-2">{term}</dt>
              <dd class="text-slate-600 leading-relaxed">{definition}</dd>
            </div>
          ))}
        </dl>
      </div>
    );
  })}

  <!-- CTA -->
  <div class="bg-slate-900 text-white rounded-[2rem] p-10 text-center mt-8">
    <h2 class="text-3xl font-bold mb-4">Still Have Questions?</h2>
    <p class="text-slate-300 mb-8">Our AI advisor can answer solar questions specific to your home and electricity bill.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="index.html" class="inline-block bg-indigo-600 hover:bg-indigo-700 px-8 py-4 rounded-2xl font-bold transition">
        Get My Solar Estimate
      </a>
      <a href="faq.html" class="inline-block bg-slate-700 hover:bg-slate-600 px-8 py-4 rounded-2xl font-bold transition">
        Browse All FAQs
      </a>
    </div>
  </div>

</div>

</BaseLayout>

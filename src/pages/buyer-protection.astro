---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout pageKey="buyer-protection.html">

<section class="bg-gradient-to-br from-slate-900 to-slate-800 text-white py-24">

<div class="max-w-4xl mx-auto px-6 text-center">

<div class="text-indigo-300 uppercase tracking-widest text-sm mb-4">
BUYER PROTECTION
</div>

<h1 class="text-5xl font-bold mb-6">
Protecting Homeowners From Costly Solar Mistakes
</h1>

<p class="text-xl text-slate-300">
Independent guidance designed to help you make informed solar decisions.
</p>

</div>

</section>

<section class="py-20">

<div class="max-w-6xl mx-auto px-6">

<h2 class="text-4xl font-bold mb-12 text-center">
Our Buyer Protection Principles
</h2>

<div class="grid md:grid-cols-2 gap-8">

<div class="bg-white p-8 rounded-3xl shadow-sm">
<div class="text-4xl mb-4">⚖️</div>
<h3 class="font-bold text-xl mb-3">
Installer Neutrality
</h3>
<p class="text-slate-600">
We do not recommend installers based on commissions.
Recommendations focus on suitability, certifications, experience and customer service.
</p>
</div>

<div class="bg-white p-8 rounded-3xl shadow-sm">
<div class="text-4xl mb-4">💰</div>
<h3 class="font-bold text-xl mb-3">
Transparent Pricing
</h3>
<p class="text-slate-600">
We help homeowners understand realistic installation costs and avoid inflated quotations.
</p>
</div>

<div class="bg-white p-8 rounded-3xl shadow-sm">
<div class="text-4xl mb-4">🏛️</div>
<h3 class="font-bold text-xl mb-3">
Subsidy Awareness
</h3>
<p class="text-slate-600">
We provide educational guidance regarding current solar subsidy programs and eligibility.
</p>
</div>

<div class="bg-white p-8 rounded-3xl shadow-sm">
<div class="text-4xl mb-4">🔍</div>
<h3 class="font-bold text-xl mb-3">
Proposal Verification
</h3>
<p class="text-slate-600">
Upload installer proposals for independent AI review and risk assessment.
</p>
</div>

</div>

</div>

</section>

<section class="py-20 bg-white">

<div class="max-w-5xl mx-auto px-6">

<h2 class="text-4xl font-bold mb-10 text-center">
Before You Sign Any Solar Contract
</h2>

<div class="space-y-4">

<div class="bg-slate-50 p-6 rounded-2xl">
✅ Verify panel brand and warranty duration
</div>

<div class="bg-slate-50 p-6 rounded-2xl">
✅ Confirm inverter specifications
</div>

<div class="bg-slate-50 p-6 rounded-2xl">
✅ Ensure subsidy eligibility documentation is included
</div>

<div class="bg-slate-50 p-6 rounded-2xl">
✅ Confirm installation timeline
</div>

<div class="bg-slate-50 p-6 rounded-2xl">
✅ Review after-sales support commitments
</div>

<div class="bg-slate-50 p-6 rounded-2xl">
✅ Check net metering support process
</div>

</div>

</div>

</section>

<section class="py-20">

<div class="max-w-5xl mx-auto px-6">

<div class="bg-gradient-to-r from-indigo-600 to-indigo-700 text-white p-10 rounded-3xl">

<h2 class="text-3xl font-bold mb-4">
Our Promise
</h2>

<p class="text-lg leading-relaxed">
Solar AI Advisor exists to help homeowners make informed solar decisions.
We believe transparency, education and independent analysis lead to better outcomes for everyone.
</p>

</div>

</div>

</section>

<section class="bg-slate-900 text-white py-24 text-center">

<div class="max-w-3xl mx-auto px-6">

<h2 class="text-4xl font-bold mb-6">
Get Your Independent Solar Assessment
</h2>

<p class="text-slate-300 mb-8">
Discover your solar potential in under 60 seconds.
</p>

<a href="index.html"
class="inline-block bg-emerald-600 hover:bg-emerald-700 px-8 py-4 rounded-2xl font-bold">
Calculate My Savings
</a>

</div>

</section>

</BaseLayout>

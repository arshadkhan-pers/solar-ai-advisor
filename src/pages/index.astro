<div id="leadPopup" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-[150] backdrop-blur-md p-4">
  <div class="bg-white p-8 rounded-[2.5rem] w-full max-w-md text-center shadow-2xl relative">
